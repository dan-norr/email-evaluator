# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...

# Gmail OAuth (opcional — usar se PROVIDER=gmail)
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:3000/oauth/callback
GMAIL_REFRESH_TOKEN=

# IMAP (opcional — usar se PROVIDER=imap)
IMAP_HOST=imap.gmail.com
IMAP_PORT=993
IMAP_USER=
IMAP_PASS=
IMAP_TLS=true

# Provider ativo: "gmail" | "imap"
EMAIL_PROVIDER=gmail

# WhatsApp — Evolution API
EVOLUTION_API_URL=https://your-evolution-instance.com
EVOLUTION_API_KEY=
EVOLUTION_INSTANCE=default
WHATSAPP_NOTIFY_NUMBER=5511999999999

# Cron interval em minutos (ex: "*/5" = a cada 5 min)
POLL_CRON=*/5 * * * *

# Urgency threshold — scores >= este valor disparam notificação WhatsApp (0-10)
URGENCY_THRESHOLD=7
